modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start ecosystem-analytics"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start wallet-app"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/universe-hub && PORT=5000 BASE_PATH=/ pnpm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && node ./build.mjs && PORT=8080 node --enable-source-maps ./dist/index.mjs"

[[workflows.workflow]]
name = "Start ecosystem-analytics"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3002 BASE_PATH=/ pnpm --filter @workspace/ecosystem-analytics run dev"
waitForPort = 3002

[[workflows.workflow]]
name = "Start wallet-app"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 BASE_PATH=/wallet-app pnpm --filter @workspace/wallet-app run dev"
waitForPort = 3001

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3001
externalPort = 3001

[nix]
channel = "stable-25_05"
packages = ["lsof"]

[userenv]

[userenv.shared]
PORT = "5000"
BASE_PATH = "/"
UNIVERSE_ACCOUNT_API_URL = "https://hongmongkhoinguyen-taikhoanvutru--manifestanhthu3.replit.app"
