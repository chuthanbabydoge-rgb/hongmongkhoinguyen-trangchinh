modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start ecosystem-analytics"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start wallet-app"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && PORT=5000 BASE_PATH=/ pnpm --filter @workspace/universe-hub run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/artifacts/api-server && node ./build.mjs && PORT=8080 node --enable-source-maps ./dist/index.mjs"
waitForPort = 8080

[[workflows.workflow]]
name = "Start ecosystem-analytics"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/artifacts/ecosystem-analytics && PORT=3002 BASE_PATH=/ pnpm run dev"
waitForPort = 3002

[[workflows.workflow]]
name = "Start wallet-app"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/artifacts/wallet-app && PORT=3001 BASE_PATH=/wallet-app pnpm run dev"
waitForPort = 3001

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[nix]
channel = "stable-25_05"
packages = ["lsof"]

[userenv]

[userenv.shared]
